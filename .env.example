# Copy this file to .env and fill in your own free-tier keys.
# Expo inlines any EXPO_PUBLIC_* variable into the client bundle at build
# time, so these are safe to read on-device but are NOT server secrets.

# Supabase project settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# https://console.groq.com/keys (free tier, primary provider)
EXPO_PUBLIC_GROQ_API_KEY=

# https://aistudio.google.com/apikey (free tier, fallback #1)
EXPO_PUBLIC_GEMINI_API_KEY=

# https://openrouter.ai/keys (free tier, fallback #2 — uses a ":free" model)
EXPO_PUBLIC_OPENROUTER_API_KEY=

# https://tavily.com (free tier: 1,000 searches/month). Optional — powers
# automatic live web search for questions that read as needing current info
# ("latest", "today", "current price", etc). Leave blank to disable; the app
# just answers from the model's own knowledge in that case.
EXPO_PUBLIC_TAVILY_API_KEY=

# https://sentry.io (free tier: 5k errors/month). Optional — reports crashes
# and uncaught errors so you can see production issues after shipping. Leave
# blank to disable; the app runs with zero crash reporting in that case.
EXPO_PUBLIC_SENTRY_DSN=

# DEV-ONLY, local testing convenience. Deliberately has NO EXPO_PUBLIC_
# prefix so Metro never inlines it into the app bundle — it's read only by
# scripts/dev-magic-link.mjs (a plain Node script), never by app code.
# From Supabase Dashboard -> Project Settings -> API -> service_role secret.
# Do NOT commit a real value. Do NOT ever add an EXPO_PUBLIC_ prefix to this.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override if your dev server runs somewhere other than :8081.
DEV_LOGIN_APP_URL=http://localhost:8081
